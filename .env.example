# Copy to `.env` and fill in values. Never commit real secrets.

# --- PyPI: publish the `tongflow` package (`pnpm tongflow:publish`) ---
# Create a token at https://pypi.org/manage/account/token/ (Entire account or project-scoped).
# For API token auth, username must be exactly: __token__
# TWINE_USERNAME=__token__
# TWINE_PASSWORD=pypi-xxxxxxxx
# TestPyPI token: https://test.pypi.org/manage/account/token/  (use TONGFLOW_UPLOAD_TESTPYPI=1 pnpm tongflow:publish)

# --- Modal (GPU/CPU workers) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# --- Text generation: default route (`gen_text` → OpenRouter free router) ---
OPENROUTER_API_KEY=
# Optional overrides:
# OPENROUTER_FREE_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=TongFlow

# --- Text generation: Google Gemini (`gen_text_gemini`, combine_text default path, etc.) ---
# Use either name; handler accepts both.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Text generation: OpenAI (`gen_text_openai`) ---
OPENAI_API_KEY=
# Default model when the node does not pick one (optional):
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Other providers ---
# DeepSeek API (e.g. batch “arrange / group” text logic in `arrange-texts` handler)
# DEEPSEEK_API_KEY=

# Optional: secure task webhook + auto-save callbacks from external runners
# TASK_WEBHOOK_TOKEN=

# --- Optional app URLs ---
# NEXT_PUBLIC_FILE_BASE_URL=
