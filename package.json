{
    "name": "tongflow",
    "version": "0.1.2",
    "description": "A multi-modal AIGC studio for building generative AI workflows",
    "author": "tong-io",
    "keywords": [
        "aigc",
        "ai",
        "workflow",
        "multimodal",
        "next.js"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/tong-io/tongflow"
    },
    "homepage": "https://github.com/tong-io/tongflow#readme",
    "license": "AGPL-3.0-only",
    "private": true,
    "pnpm": {
        "onlyBuiltDependencies": [
            "@swc/core",
            "better-sqlite3",
            "cbor-extract",
            "esbuild",
            "protobufjs",
            "sharp"
        ]
    },
    "scripts": {
        "predev": "pnpm gen:abi",
        "dev": "next dev",
        "prebuild": "pnpm gen:abi",
        "build": "next build",
        "start": "next start",
        "start:prod": "pnpm build && pnpm start",
        "plugins:install": "node scripts/install-official-plugins.mjs",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "lint": "pnpm exec biome format --write",
        "lint:check": "pnpm exec biome check --error-on-warnings .",
        "typecheck": "tsc --noEmit",
        "gen:abi": "tsx scripts/gen-abi-types.ts",
        "abi:generate": "node scripts/generate-tongflow-abi.mjs",
        "tongflow:publish": "bash scripts/publish-tongflow-pypi.sh",
        "test": "vitest run",
        "verify:plugins": "tsx scripts/verify-plugins-scan.ts"
    },
    "dependencies": {
        "@google/genai": "1.47.0",
        "@hookform/resolvers": "5.2.1",
        "@radix-ui/react-alert-dialog": "1.1.15",
        "@radix-ui/react-checkbox": "1.3.3",
        "@radix-ui/react-dialog": "1.1.15",
        "@radix-ui/react-dropdown-menu": "2.1.16",
        "@radix-ui/react-label": "2.1.7",
        "@radix-ui/react-progress": "1.1.7",
        "@radix-ui/react-select": "2.2.6",
        "@radix-ui/react-separator": "1.1.7",
        "@radix-ui/react-slider": "1.3.6",
        "@radix-ui/react-slot": "1.2.3",
        "@radix-ui/react-switch": "1.2.6",
        "@radix-ui/react-tabs": "1.1.13",
        "@radix-ui/react-tooltip": "1.2.8",
        "@sparkjsdev/spark": "2.1.0",
        "@types/three": "0.183.1",
        "@xyflow/react": "12.9.0",
        "better-sqlite3": "12.2.0",
        "chokidar": "4.0.3",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "dotenv": "17.2.2",
        "drizzle-orm": "0.44.5",
        "drizzle-zod": "0.8.3",
        "isomorphic-git": "1.38.4",
        "lucide-react": "0.544.0",
        "masonic": "4.1.0",
        "nanoid": "5.1.6",
        "next": "15.5.19",
        "next-intl": "4.6.1",
        "openai": "6.33.0",
        "react": "19.2.1",
        "react-dom": "19.2.1",
        "react-hook-form": "7.62.0",
        "react-hot-toast": "2.6.0",
        "server-only": "0.0.1",
        "tailwind-merge": "3.3.1",
        "three": "0.183.2",
        "uuid": "13.0.0",
        "zod": "4.1.8",
        "zustand": "5.0.8"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.4",
        "@tailwindcss/postcss": "4",
        "@types/better-sqlite3": "7.6.8",
        "@types/json-schema": "7.0.15",
        "@types/node": "20.19.13",
        "@types/react": "19",
        "@types/react-dom": "19",
        "drizzle-kit": "0.31.4",
        "esbuild": "0.28.0",
        "json-schema-to-ts": "3.1.1",
        "tailwindcss": "4",
        "tsx": "4.20.5",
        "tw-animate-css": "1.3.8",
        "typescript": "5",
        "vitest": "4.1.5"
    }
}
